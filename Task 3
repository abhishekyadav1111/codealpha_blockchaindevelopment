### 💻 Solidity Code Example

```solidity
// SPDX-License-Identifier: MIT
pragma solidity ^0.8.0;

contract PollingSystem {
    struct Poll {
        string title;
        string[] options;
        uint endTime;
        mapping(uint => uint) votes; // option index => vote count
        mapping(address => bool) hasVoted; // track who has voted
        bool exists;
    }

    mapping(uint => Poll) public polls;
    uint public pollCount;

    // Create a new poll
    function createPoll(string memory _title, string[] memory _options, uint _durationInSeconds) public {
        require(_options.length > 1, "Need at least 2 options");
        pollCount++;
        Poll storage p = polls[pollCount];
        p.title = _title;
        p.options = _options;
        p.endTime = block.timestamp + _durationInSeconds;
        p.exists = true;
    }

    // Vote for an option by index
    function vote(uint _pollId, uint _optionIndex) public {
        Poll storage p = polls[_pollId];
        require(p.exists, "Poll does not exist");
        require(block.timestamp < p.endTime, "Voting has ended");
        require(!p.hasVoted[msg.sender], "Already voted");
        require(_optionIndex < p.options.length, "Invalid option");

        p.votes[_optionIndex] += 1;
        p.hasVoted[msg.sender] = true;
    }

    // Get vote count for an option
    function getVotes(uint _pollId, uint _optionIndex) public view returns (uint) {
        Poll storage p = polls[_pollId];
        require(p.exists, "Poll does not exist");
        return p.votes[_optionIndex];
    }

    // Determine the winning option after poll ends
    function getWinner(uint _pollId) public view returns (string memory) {
        Poll storage p = polls[_pollId];
        require(p.exists, "Poll does not exist");
        require(block.timestamp >= p.endTime, "Poll still active");

        uint winningVoteCount = 0;
        uint winningIndex = 0;

        for (uint i = 0; i < p.options.length; i++) {
            if (p.votes[i] > winningVoteCount) {
                winningVoteCount = p.votes[i];
                winningIndex = i;
            }
        }
        return p.options[winningIndex];
    }

    // Get poll details (title, options, end time)
    function getPollDetails(uint _pollId) public view returns (string memory, string[] memory, uint) {
        Poll storage p = polls[_pollId];
        require(p.exists, "Poll does not exist");
        return (p.title, p.options, p.endTime);
    }
}
```

---

### ⚙️ How It Works
- **createPoll**: Users provide a title, options, and voting deadline.  
- **vote**: Each address can vote only once before the deadline.  
- **getVotes**: Check votes for a specific option.  
- **getWinner**: After the poll ends, returns the winning option.  
- **Mappings** ensure secure vote tracking and prevent double voting.  
